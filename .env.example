NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated Stellar Horizon base URLs.
# Every endpoint must serve the same Stellar network.
# Do not mix mainnet, testnet, futurenet, or local-network endpoints.
# At least one endpoint is required by the latest-ledger API route.
# Whitespace is trimmed; duplicate endpoints are ignored.
STELLAR_HORIZON_URLS=https://horizon.stellar.org
